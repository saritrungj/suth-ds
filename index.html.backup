<span class="token-tag">&lt;div</span> <span class="token-attr">class</span>=<span class="token-value">"pb-4"</span><span class="token-tag">&gt;</span>Padding bottom<span class="token-tag">&lt;/div&gt;</span>
<span class="token-tag">&lt;div</span> <span class="token-attr">class</span>=<span class="token-value">"pl-4"</span><span class="token-tag">&gt;</span>Padding left<span class="token-tag">&lt;/div&gt;</span>

