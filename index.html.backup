                <div style="width: 64px; height: 64px; background: white; border-radius: 10px; box-shadow: 0 1px 2px 0 rgba(0, 0, 0, 0.05); display: flex; align-items: center; justify-content: center; font-size: 0.6875rem; color: var(--slate-500);">xs</div>
                <code style="font-size: 0.6875rem; color: var(--slate-600);">--shadow-xs</code>
              </div>
              <div style="display: flex; flex-direction: column; align-items: center; gap: 10px;">
                <div style="width: 64px; height: 64px; background: white; border-radius: 10px; box-shadow: 0 1px 3px 0 rgba(0, 0, 0, 0.1), 0 1px 2px -1px rgba(0, 0, 0, 0.1); display: flex; align-items: center; justify-content: center; font-size: 0.6875rem; color: var(--slate-500);">sm</div>
                <code style="font-size: 0.6875rem; color: var(--slate-600);">--shadow-sm</code>
              </div>
              <div style="display: flex; flex-direction: column; align-items: center; gap: 10px;">
                <div style="width: 64px; height: 64px; background: white; border-radius: 10px; box-shadow: 0 4px 6px -1px rgba(0, 0, 0, 0.1), 0 2px 4px -2px rgba(0, 0, 0, 0.1); display: flex; align-items: center; justify-content: center; font-size: 0.6875rem; color: var(--slate-500);">md</div>
                <code style="font-size: 0.6875rem; color: var(--slate-600);">--shadow-md</code>
              </div>
              <div style="display: flex; flex-direction: column; align-items: center; gap: 10px;">
                <div style="width: 64px; height: 64px; background: white; border-radius: 10px; box-shadow: 0 10px 15px -3px rgba(0, 0, 0, 0.1), 0 4px 6px -4px rgba(0, 0, 0, 0.1); display: flex; align-items: center; justify-content: center; font-size: 0.6875rem; color: var(--slate-500);">lg</div>
                <code style="font-size: 0.6875rem; color: var(--slate-600);">--shadow-lg</code>
              </div>
              <div style="display: flex; flex-direction: column; align-items: center; gap: 10px;">
                <div style="width: 64px; height: 64px; background: white; border-radius: 10px; box-shadow: 0 20px 25px -5px rgba(0, 0, 0, 0.1), 0 8px 10px -6px rgba(0, 0, 0, 0.1); display: flex; align-items: center; justify-content: center; font-size: 0.6875rem; color: var(--slate-500);">xl</div>
                <code style="font-size: 0.6875rem; color: var(--slate-600);">--shadow-xl</code>
              </div>
              <div style="display: flex; flex-direction: column; align-items: center; gap: 10px;">
                <div style="width: 64px; height: 64px; background: white; border-radius: 10px; box-shadow: 0 25px 50px -12px rgba(0, 0, 0, 0.25); display: flex; align-items: center; justify-content: center; font-size: 0.6875rem; color: var(--slate-500);">2xl</div>
                <code style="font-size: 0.6875rem; color: var(--slate-600);">--shadow-2xl</code>
              </div>
