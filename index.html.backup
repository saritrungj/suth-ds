          </div>
          <div class="ds-component-preview">
            <div class="preview-row">
              <button class="btn btn-primary btn-press-effect">
                <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M16 21v-2a4 4 0 0 0-4-4H5a4 4 0 0 0-4 4v2"/><circle cx="8.5" cy="7" r="4"/><line x1="20" y1="8" x2="20" y2="14"/><line x1="23" y1="11" x2="17" y2="11"/></svg>
                New Patient
              </button>
              <button class="btn btn-success btn-press-effect">
                <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polyline points="20 6 9 17 4 12"/></svg>
                Save Record
              </button>
              <span class="badge badge-primary">Active</span>
              <span class="badge badge-success badge-pulse">New</span>
            </div>
          </div>
          <div class="ds-component-code">
            <div class="ds-component-code-header">
              <span class="ds-component-code-lang">HTML</span>
            </div>
            <pre id="install-basic"><code><span class="token-comment">&lt;!-- Button with SVG icon --&gt;</span>
<span class="token-tag">&lt;button</span> <span class="token-attr">class</span>=<span class="token-value">"btn btn-primary"</span><span class="token-tag">&gt;</span>
  <span class="token-tag">&lt;svg</span> <span class="token-attr">xmlns</span>=<span class="token-value">"http://www.w3.org/2000/svg"</span> <span class="token-attr">width</span>=<span class="token-value">"16"</span> <span class="token-attr">height</span>=<span class="token-value">"16"</span> <span class="token-attr">viewBox</span>=<span class="token-value">"0 0 24 24"</span> <span class="token-attr">fill</span>=<span class="token-value">"none"</span> <span class="token-attr">stroke</span>=<span class="token-value">"currentColor"</span> <span class="token-attr">stroke-width</span>=<span class="token-value">"2"</span><span class="token-tag">&gt;&lt;path</span> <span class="token-attr">d</span>=<span class="token-value">"M2 21a8 8 0 0 1 13.292-6"</span><span class="token-tag">/&gt;&lt;circle</span> <span class="token-attr">cx</span>=<span class="token-value">"10"</span> <span class="token-attr">cy</span>=<span class="token-value">"8"</span> <span class="token-attr">r</span>=<span class="token-value">"5"</span><span class="token-tag">/&gt;&lt;path</span> <span class="token-attr">d</span>=<span class="token-value">"M19 16v6"</span><span class="token-tag">/&gt;&lt;path</span> <span class="token-attr">d</span>=<span class="token-value">"M22 19h-6"</span><span class="token-tag">/&gt;&lt;/svg&gt;</span>
  New Patient
