              </div>
              <div style="background: var(--primary-100); padding: 8px; border-radius: var(--radius-md);">
                <div class="m-1" style="background: white; padding: 8px; border: 2px dashed var(--primary-400); border-radius: var(--radius-sm); margin: 4px;">m-1 (4px)</div>
              </div>
              <div style="background: var(--primary-100); padding: 8px; border-radius: var(--radius-md);">
                <div class="m-2" style="background: white; padding: 8px; border: 2px dashed var(--primary-400); border-radius: var(--radius-sm); margin: 8px;">m-2 (8px)</div>
              </div>
              <div style="background: var(--primary-100); padding: 8px; border-radius: var(--radius-md);">
                <div class="m-4" style="background: white; padding: 8px; border: 2px dashed var(--primary-400); border-radius: var(--radius-sm); margin: 16px;">m-4 (16px)</div>
              </div>
              <div style="background: var(--primary-100); padding: 8px; border-radius: var(--radius-md);">
                <div class="m-6" style="background: white; padding: 8px; border: 2px dashed var(--primary-400); border-radius: var(--radius-sm); margin: 24px;">m-6 (24px)</div>
              </div>
            </div>
          </div>
          <div class="ds-component-code">
            <div class="ds-component-code-header">
              <span class="ds-component-code-lang">HTML</span>
            </div>
            <pre id="spacing-margin"><code><span class="token-comment">&lt;!-- Margin all sides --&gt;</span>
<span class="token-tag">&lt;div</span> <span class="token-attr">class</span>=<span class="token-value">"m-0"</span><span class="token-tag">&gt;</span>No margin<span class="token-tag">&lt;/div&gt;</span>
<span class="token-tag">&lt;div</span> <span class="token-attr">class</span>=<span class="token-value">"m-1"</span><span class="token-tag">&gt;</span>4px margin<span class="token-tag">&lt;/div&gt;</span>
<span class="token-tag">&lt;div</span> <span class="token-attr">class</span>=<span class="token-value">"m-2"</span><span class="token-tag">&gt;</span>8px margin<span class="token-tag">&lt;/div&gt;</span>
<span class="token-tag">&lt;div</span> <span class="token-attr">class</span>=<span class="token-value">"m-4"</span><span class="token-tag">&gt;</span>16px margin<span class="token-tag">&lt;/div&gt;</span>
<span class="token-tag">&lt;div</span> <span class="token-attr">class</span>=<span class="token-value">"m-6"</span><span class="token-tag">&gt;</span>24px margin<span class="token-tag">&lt;/div&gt;</span>
<span class="token-tag">&lt;div</span> <span class="token-attr">class</span>=<span class="token-value">"m-8"</span><span class="token-tag">&gt;</span>32px margin<span class="token-tag">&lt;/div&gt;</span>

<span class="token-comment">&lt;!-- Margin top, right, bottom, left --&gt;</span>
<span class="token-tag">&lt;div</span> <span class="token-attr">class</span>=<span class="token-value">"mt-4"</span><span class="token-tag">&gt;</span>Margin top<span class="token-tag">&lt;/div&gt;</span>
<span class="token-tag">&lt;div</span> <span class="token-attr">class</span>=<span class="token-value">"mr-4"</span><span class="token-tag">&gt;</span>Margin right<span class="token-tag">&lt;/div&gt;</span>
<span class="token-tag">&lt;div</span> <span class="token-attr">class</span>=<span class="token-value">"mb-4"</span><span class="token-tag">&gt;</span>Margin bottom<span class="token-tag">&lt;/div&gt;</span>
<span class="token-tag">&lt;div</span> <span class="token-attr">class</span>=<span class="token-value">"ml-4"</span><span class="token-tag">&gt;</span>Margin left<span class="token-tag">&lt;/div&gt;</span>

<span class="token-comment">&lt;!-- Margin X and Y axis --&gt;</span>
<span class="token-tag">&lt;div</span> <span class="token-attr">class</span>=<span class="token-value">"mx-4"</span><span class="token-tag">&gt;</span>Margin left & right<span class="token-tag">&lt;/div&gt;</span>
<span class="token-tag">&lt;div</span> <span class="token-attr">class</span>=<span class="token-value">"my-4"</span><span class="token-tag">&gt;</span>Margin top & bottom<span class="token-tag">&lt;/div&gt;</span>

<span class="token-comment">&lt;!-- Auto margin --&gt;</span>
<span class="token-tag">&lt;div</span> <span class="token-attr">class</span>=<span class="token-value">"mx-auto"</span><span class="token-tag">&gt;</span>Center horizontally<span class="token-tag">&lt;/div&gt;</span></code></pre>
          </div>
        </div>
        
        <div class="ds-component">
