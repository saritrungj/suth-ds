            <p class="ds-section-desc">Common UI patterns for recurring problems.</p>
          </div>
          <span class="ds-section-badge">
            <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect x="3" y="3" width="7" height="7"/><rect x="14" y="3" width="7" height="7"/></svg>
            3 Types
          </span>
        </div>
        
        <div class="ds-component">
          <div class="ds-component-header">
            <span class="ds-component-title">UI State Patterns</span>
            <button class="btn-copy" onclick="copyCode('pattern-empty')">
              <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect x="9" y="9" width="13" height="13" rx="2"/><path d="M5 15H4a2 2 0 0 1-2-2V4a2 2 0 0 1 2-2h9a2 2 0 0 1 2 2v1"/></svg>
              Copy
            </button>
          </div>
          <div class="ds-component-preview">
            <div style="display: grid; grid-template-columns: repeat(auto-fit, minmax(200px, 1fr)); gap: 16px;">
              <!-- Empty State -->
              <div style="padding: 32px 16px; text-align: center; background: var(--slate-50); border-radius: 10px; border: 2px dashed var(--slate-300);">
                <svg width="40" height="40" viewBox="0 0 24 24" fill="none" stroke="var(--slate-400)" stroke-width="1.5" style="margin: 0 auto 12px;"><path d="M13 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V9z"/><polyline points="13 2 13 9 20 9"/></svg>
                <h4 style="font-size: 0.875rem; font-weight: 600; color: var(--slate-700); margin-bottom: 4px;">No Documents</h4>
                <p style="font-size: 0.75rem; color: var(--slate-500); margin-bottom: 12px;">Upload your first file.</p>
                <button class="btn btn-primary btn-sm">Upload</button>
              </div>
              <!-- Loading State -->
              <div style="padding: 24px; background: white; border-radius: 10px; border: 1px solid var(--slate-200);">
                <div style="display: flex; align-items: center; gap: 10px; margin-bottom: 12px;">
                  <div style="width: 20px; height: 20px; border: 2px solid var(--slate-200); border-top-color: var(--primary-600); border-radius: 50%; animation: spin 1s linear infinite;"></div>
                  <span style="font-size: 0.8125rem; color: var(--slate-600);">Loading...</span>
                </div>
                <div style="display: flex; flex-direction: column; gap: 8px;">
                  <div style="height: 8px; background: var(--slate-200); border-radius: 4px; width: 80%; animation: pulse 2s infinite;"></div>
                  <div style="height: 8px; background: var(--slate-200); border-radius: 4px; width: 60%; animation: pulse 2s infinite 0.1s;"></div>
                </div>
              </div>
              <!-- Error State -->
              <div style="padding: 24px; text-align: center; background: var(--error-50); border-radius: 10px; border: 1px solid var(--error-200);">
                <svg width="36" height="36" viewBox="0 0 24 24" fill="none" stroke="var(--error-500)" stroke-width="1.5" style="margin: 0 auto 10px;"><circle cx="12" cy="12" r="10"/><line x1="15" y1="9" x2="9" y2="15"/><line x1="9" y1="9" x2="15" y2="15"/></svg>
                <h4 style="font-size: 0.875rem; font-weight: 600; color: var(--error-700); margin-bottom: 4px;">Page Not Found</h4>
                <p style="font-size: 0.75rem; color: var(--error-600); margin-bottom: 12px;">The page doesn't exist.</p>
                <button class="btn btn-secondary btn-sm">Go Home</button>
              </div>
              <!-- Inline Error -->
              <div style="padding: 16px; background: white; border-radius: 10px; border: 1px solid var(--error-300);">
                <div style="display: flex; align-items: flex-start; gap: 10px;">
                  <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="var(--error-500)" stroke-width="2" style="flex-shrink: 0;"><circle cx="12" cy="12" r="10"/><line x1="12" y1="8" x2="12" y2="12"/><line x1="12" y1="16" x2="12.01" y2="16"/></svg>
                  <div>
                    <h4 style="font-size: 0.8125rem; font-weight: 600; color: var(--error-700); margin-bottom: 2px;">Connection Error</h4>
                    <p style="font-size: 0.75rem; color: var(--slate-600);">Check your internet connection.</p>
                  </div>
                </div>
              </div>
            </div>
          </div>
          <div class="ds-component-code">
            <div class="ds-component-code-header">
              <span class="ds-component-code-lang">HTML</span>
            </div>
            <pre id="pattern-empty"><code><span class="token-comment">&lt;!-- Empty State --&gt;</span>
<span class="token-tag">&lt;div</span> <span class="token-attr">style</span>=<span class="token-value">"padding: 32px; text-align: center; background: var(--slate-50); border-radius: 10px; border: 2px dashed var(--slate-300);"</span><span class="token-tag">&gt;</span>
  <span class="token-tag">&lt;svg</span> <span class="token-attr">width</span>=<span class="token-value">"40"</span> <span class="token-attr">height</span>=<span class="token-value">"40"</span> <span class="token-attr">stroke</span>=<span class="token-value">"var(--slate-400)"</span><span class="token-tag">&gt;</span>...<span class="token-tag">&lt;/svg&gt;</span>
  <span class="token-tag">&lt;h4</span> <span class="token-attr">style</span>=<span class="token-value">"font-size: 0.875rem; font-weight: 600; color: var(--slate-700);"</span><span class="token-tag">&gt;</span>No Documents<span class="token-tag">&lt;/h4&gt;</span>
  <span class="token-tag">&lt;p</span> <span class="token-attr">style</span>=<span class="token-value">"font-size: 0.75rem; color: var(--slate-500);"</span><span class="token-tag">&gt;</span>Upload your first file.<span class="token-tag">&lt;/p&gt;</span>
  <span class="token-tag">&lt;button</span> <span class="token-attr">class</span>=<span class="token-value">"btn btn-primary btn-sm"</span><span class="token-tag">&gt;</span>Upload<span class="token-tag">&lt;/button&gt;</span>
<span class="token-tag">&lt;/div&gt;</span>

<span class="token-comment">&lt;!-- Loading State --&gt;</span>
<span class="token-tag">&lt;div</span> <span class="token-attr">style</span>=<span class="token-value">"display: flex; align-items: center; gap: 10px;"</span><span class="token-tag">&gt;</span>
  <span class="token-tag">&lt;div</span> <span class="token-attr">style</span>=<span class="token-value">"width: 20px; height: 20px; border: 2px solid var(--slate-200); border-top-color: var(--primary-600); border-radius: 50%; animation: spin 1s linear infinite;"</span><span class="token-tag">&gt;&lt;/div&gt;</span>
  <span class="token-tag">&lt;span</span> <span class="token-attr">style</span>=<span class="token-value">"font-size: 0.8125rem; color: var(--slate-600);"</span><span class="token-tag">&gt;</span>Loading...<span class="token-tag">&lt;/span&gt;</span>
<span class="token-tag">&lt;/div&gt;</span>
<span class="token-tag">&lt;div</span> <span class="token-attr">style</span>=<span class="token-value">"height: 8px; background: var(--slate-200); border-radius: 4px; width: 80%; animation: pulse 2s infinite;"</span><span class="token-tag">&gt;&lt;/div&gt;</span>

<span class="token-comment">&lt;!-- Error State --&gt;</span>
<span class="token-tag">&lt;div</span> <span class="token-attr">style</span>=<span class="token-value">"padding: 24px; text-align: center; background: var(--error-50); border-radius: 10px; border: 1px solid var(--error-200);"</span><span class="token-tag">&gt;</span>
  <span class="token-tag">&lt;svg</span> <span class="token-attr">width</span>=<span class="token-value">"36"</span> <span class="token-attr">height</span>=<span class="token-value">"36"</span> <span class="token-attr">stroke</span>=<span class="token-value">"var(--error-500)"</span><span class="token-tag">&gt;</span>...<span class="token-tag">&lt;/svg&gt;</span>
  <span class="token-tag">&lt;h4</span> <span class="token-attr">style</span>=<span class="token-value">"font-size: 0.875rem; font-weight: 600; color: var(--error-700);"</span><span class="token-tag">&gt;</span>Page Not Found<span class="token-tag">&lt;/h4&gt;</span>
  <span class="token-tag">&lt;p</span> <span class="token-attr">style</span>=<span class="token-value">"font-size: 0.75rem; color: var(--error-600);"</span><span class="token-tag">&gt;</span>The page doesn't exist.<span class="token-tag">&lt;/p&gt;</span>
  <span class="token-tag">&lt;button</span> <span class="token-attr">class</span>=<span class="token-value">"btn btn-secondary btn-sm"</span><span class="token-tag">&gt;</span>Go Home<span class="token-tag">&lt;/button&gt;</span>
<span class="token-tag">&lt;/div&gt;</span>

<span class="token-comment">&lt;!-- Inline Error --&gt;</span>
<span class="token-tag">&lt;div</span> <span class="token-attr">style</span>=<span class="token-value">"display: flex; align-items: flex-start; gap: 10px; padding: 16px; border: 1px solid var(--error-300); border-radius: 10px;"</span><span class="token-tag">&gt;</span>
  <span class="token-tag">&lt;svg</span> <span class="token-attr">width</span>=<span class="token-value">"18"</span> <span class="token-attr">height</span>=<span class="token-value">"18"</span> <span class="token-attr">stroke</span>=<span class="token-value">"var(--error-500)"</span><span class="token-tag">&gt;</span>...<span class="token-tag">&lt;/svg&gt;</span>
  <span class="token-tag">&lt;div&gt;</span>
    <span class="token-tag">&lt;h4</span> <span class="token-attr">style</span>=<span class="token-value">"font-size: 0.8125rem; font-weight: 600; color: var(--error-700);"</span><span class="token-tag">&gt;</span>Connection Error<span class="token-tag">&lt;/h4&gt;</span>
    <span class="token-tag">&lt;p</span> <span class="token-attr">style</span>=<span class="token-value">"font-size: 0.75rem; color: var(--slate-600);"</span><span class="token-tag">&gt;</span>Check your internet connection.<span class="token-tag">&lt;/p&gt;</span>
  <span class="token-tag">&lt;/div&gt;</span>
<span class="token-tag">&lt;/div&gt;</span></code></pre>
