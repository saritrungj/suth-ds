            <button class="btn-copy" onclick="copyCode('tokens-css')">
              <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect x="9" y="9" width="13" height="13" rx="2"/><path d="M5 15H4a2 2 0 0 1-2-2V4a2 2 0 0 1 2-2h9a2 2 0 0 1 2 2v1"/></svg>
              Copy
            </button>
          </div>
          <div class="ds-component-preview">
            <div style="display: grid; grid-template-columns: repeat(auto-fit, minmax(200px, 1fr)); gap: 16px;">
              <div class="token-group" style="background: var(--slate-50); padding: 16px; border-radius: 10px; border: 1px solid var(--slate-200);">
                <h4 style="font-size: 0.75rem; font-weight: 600; color: var(--slate-600); margin-bottom: 10px; text-transform: uppercase; letter-spacing: 0.05em;">Colors</h4>
                <div style="font-family: monospace; font-size: 0.75rem; line-height: 1.7;">
                  <div style="display: flex; justify-content: space-between; padding: 4px 0; border-bottom: 1px solid var(--slate-200);"><code>--primary-500</code> <span style="color: var(--slate-500);">#3B82F6</span></div>
                  <div style="display: flex; justify-content: space-between; padding: 4px 0; border-bottom: 1px solid var(--slate-200);"><code>--success-500</code> <span style="color: var(--slate-500);">#10B981</span></div>
                  <div style="display: flex; justify-content: space-between; padding: 4px 0; border-bottom: 1px solid var(--slate-200);"><code>--warning-500</code> <span style="color: var(--slate-500);">#F59E0B</span></div>
                  <div style="display: flex; justify-content: space-between; padding: 4px 0; border-bottom: 1px solid var(--slate-200);"><code>--error-500</code> <span style="color: var(--slate-500);">#EF4444</span></div>
                  <div style="display: flex; justify-content: space-between; padding: 4px 0;"><code>--slate-500</code> <span style="color: var(--slate-500);">#64748B</span></div>
                </div>
              </div>
              <div class="token-group" style="background: var(--slate-50); padding: 16px; border-radius: 10px; border: 1px solid var(--slate-200);">
                <h4 style="font-size: 0.75rem; font-weight: 600; color: var(--slate-600); margin-bottom: 10px; text-transform: uppercase; letter-spacing: 0.05em;">Typography</h4>
                <div style="font-family: monospace; font-size: 0.75rem; line-height: 1.7;">
                  <div style="display: flex; justify-content: space-between; padding: 4px 0; border-bottom: 1px solid var(--slate-200);"><code>--font-base</code> <span style="color: var(--slate-500);">'Anuphan'</span></div>
                  <div style="display: flex; justify-content: space-between; padding: 4px 0; border-bottom: 1px solid var(--slate-200);"><code>--text-sm</code> <span style="color: var(--slate-500);">13px</span></div>
                  <div style="display: flex; justify-content: space-between; padding: 4px 0; border-bottom: 1px solid var(--slate-200);"><code>--text-base</code> <span style="color: var(--slate-500);">14px</span></div>
                  <div style="display: flex; justify-content: space-between; padding: 4px 0; border-bottom: 1px solid var(--slate-200);"><code>--text-lg</code> <span style="color: var(--slate-500);">16px</span></div>
                  <div style="display: flex; justify-content: space-between; padding: 4px 0;"><code>--text-xl</code> <span style="color: var(--slate-500);">18px</span></div>
                </div>
              </div>
              <div class="token-group" style="background: var(--slate-50); padding: 16px; border-radius: 10px; border: 1px solid var(--slate-200);">
                <h4 style="font-size: 0.75rem; font-weight: 600; color: var(--slate-600); margin-bottom: 10px; text-transform: uppercase; letter-spacing: 0.05em;">Spacing</h4>
                <div style="font-family: monospace; font-size: 0.75rem; line-height: 1.7;">
                  <div style="display: flex; justify-content: space-between; padding: 4px 0; border-bottom: 1px solid var(--slate-200);"><code>--space-1</code> <span style="color: var(--slate-500);">4px</span></div>
                  <div style="display: flex; justify-content: space-between; padding: 4px 0; border-bottom: 1px solid var(--slate-200);"><code>--space-2</code> <span style="color: var(--slate-500);">8px</span></div>
                  <div style="display: flex; justify-content: space-between; padding: 4px 0; border-bottom: 1px solid var(--slate-200);"><code>--space-4</code> <span style="color: var(--slate-500);">16px</span></div>
                  <div style="display: flex; justify-content: space-between; padding: 4px 0; border-bottom: 1px solid var(--slate-200);"><code>--space-6</code> <span style="color: var(--slate-500);">24px</span></div>
                  <div style="display: flex; justify-content: space-between; padding: 4px 0;"><code>--space-8</code> <span style="color: var(--slate-500);">32px</span></div>
                </div>
              </div>
              <div class="token-group" style="background: var(--slate-50); padding: 16px; border-radius: 10px; border: 1px solid var(--slate-200);">
                <h4 style="font-size: 0.75rem; font-weight: 600; color: var(--slate-600); margin-bottom: 10px; text-transform: uppercase; letter-spacing: 0.05em;">Radius / Shadow</h4>
                <div style="font-family: monospace; font-size: 0.75rem; line-height: 1.7;">
                  <div style="display: flex; justify-content: space-between; padding: 4px 0; border-bottom: 1px solid var(--slate-200);"><code>--radius-sm</code> <span style="color: var(--slate-500);">4px</span></div>
                  <div style="display: flex; justify-content: space-between; padding: 4px 0; border-bottom: 1px solid var(--slate-200);"><code>--radius-md</code> <span style="color: var(--slate-500);">6px</span></div>
                  <div style="display: flex; justify-content: space-between; padding: 4px 0; border-bottom: 1px solid var(--slate-200);"><code>--radius-lg</code> <span style="color: var(--slate-500);">8px</span></div>
                  <div style="display: flex; justify-content: space-between; padding: 4px 0; border-bottom: 1px solid var(--slate-200);"><code>--shadow-md</code> <span style="color: var(--slate-500);">md</span></div>
                  <div style="display: flex; justify-content: space-between; padding: 4px 0;"><code>--shadow-lg</code> <span style="color: var(--slate-500);">lg</span></div>
                </div>
              </div>
            </div>
          </div>
          <div class="ds-component-code">
            <div class="ds-component-code-header">
              <span class="ds-component-code-lang">CSS</span>
            </div>
            <pre id="tokens-css"><code><span class="token-comment">/* Using Design Tokens */</span>
<span class="token-tag">.component</span> {
  <span class="token-attr">color</span>: <span class="token-value">var(--primary-600)</span>;
  <span class="token-attr">padding</span>: <span class="token-value">var(--space-4)</span>;
  <span class="token-attr">border-radius</span>: <span class="token-value">var(--radius-lg)</span>;
}</code></pre>
          </div>
        </div>
      </section>
      
