      <!-- Motion & Animation -->
      <section class="ds-section" id="motion">
        <div class="ds-section-header">
          <div>
            <h2 class="ds-section-title">Motion & Animation</h2>
            <p class="ds-section-desc">Timing and easing for smooth interactions.</p>
          </div>
          <span class="ds-section-badge">
            <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="10"/><polyline points="12 6 12 12 16 14"/></svg>
            3 Durations
          </span>
        </div>
        
        <div class="ds-component">
          <div class="ds-component-header">
            <span class="ds-component-title">Transition Tokens</span>
            <button class="btn-copy" onclick="copyCode('motion-tokens')">
              <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect x="9" y="9" width="13" height="13" rx="2"/><path d="M5 15H4a2 2 0 0 1-2-2V4a2 2 0 0 1 2-2h9a2 2 0 0 1 2 2v1"/></svg>
              Copy
            </button>
          </div>
          <div class="ds-component-preview">
            <div style="display: grid; grid-template-columns: repeat(auto-fit, minmax(280px, 1fr)); gap: 16px;">
              <div style="background: var(--slate-50); padding: 16px; border-radius: 10px; border: 1px solid var(--slate-200);">
                <h4 style="font-size: 0.75rem; font-weight: 600; color: var(--slate-600); margin-bottom: 12px; text-transform: uppercase;">Duration</h4>
                <div style="display: flex; flex-direction: column; gap: 10px;">
                  <div style="display: flex; align-items: center; gap: 10px;">
                    <div style="width: 50px; font-family: monospace; font-size: 0.75rem; color: var(--slate-600);">100ms</div>
                    <div style="flex: 1; height: 6px; background: var(--slate-200); border-radius: 3px; overflow: hidden;"><div style="width: 33%; height: 100%; background: var(--primary-500);"></div></div>
                    <code style="font-size: 0.6875rem; color: var(--slate-500);">--transition-fast</code>
                  </div>
                  <div style="display: flex; align-items: center; gap: 10px;">
                    <div style="width: 50px; font-family: monospace; font-size: 0.75rem; color: var(--slate-600);">150ms</div>
                    <div style="flex: 1; height: 6px; background: var(--slate-200); border-radius: 3px; overflow: hidden;"><div style="width: 50%; height: 100%; background: var(--primary-500);"></div></div>
                    <code style="font-size: 0.6875rem; color: var(--slate-500);">--transition-base</code>
                  </div>
                  <div style="display: flex; align-items: center; gap: 10px;">
                    <div style="width: 50px; font-family: monospace; font-size: 0.75rem; color: var(--slate-600);">300ms</div>
                    <div style="flex: 1; height: 6px; background: var(--slate-200); border-radius: 3px; overflow: hidden;"><div style="width: 100%; height: 100%; background: var(--primary-500);"></div></div>
                    <code style="font-size: 0.6875rem; color: var(--slate-500);">--transition-slow</code>
                  </div>
                </div>
              </div>
              <div style="background: var(--slate-50); padding: 16px; border-radius: 10px; border: 1px solid var(--slate-200);">
                <h4 style="font-size: 0.75rem; font-weight: 600; color: var(--slate-600); margin-bottom: 12px; text-transform: uppercase;">Easing</h4>
                <div style="font-family: monospace; font-size: 0.75rem; line-height: 1.8;">
                  <div style="display: flex; justify-content: space-between; padding: 6px 0; border-bottom: 1px solid var(--slate-200);"><code>--ease-linear</code><span style="color: var(--slate-500);">linear</span></div>
                  <div style="display: flex; justify-content: space-between; padding: 6px 0; border-bottom: 1px solid var(--slate-200);"><code>--ease-in</code><span style="color: var(--slate-500);">cubic-bezier(0.4, 0, 1, 1)</span></div>
                  <div style="display: flex; justify-content: space-between; padding: 6px 0; border-bottom: 1px solid var(--slate-200);"><code>--ease-out</code><span style="color: var(--slate-500);">cubic-bezier(0, 0, 0.2, 1)</span></div>
                  <div style="display: flex; justify-content: space-between; padding: 6px 0;"><code>--ease-in-out</code><span style="color: var(--slate-500);">cubic-bezier(0.4, 0, 0.2, 1)</span></div>
                </div>
              </div>
            </div>
          </div>
          <div class="ds-component-code">
            <div class="ds-component-code-header">
              <span class="ds-component-code-lang">CSS</span>
            </div>
            <pre id="motion-tokens"><code><span class="token-tag">.button</span> {
  <span class="token-attr">transition</span>: <span class="token-value">all var(--transition-base) var(--ease-in-out)</span>;
}
<span class="token-tag">.modal</span> {
  <span class="token-attr">animation</span>: <span class="token-value">fadeIn var(--transition-slow) ease-out</span>;
}</code></pre>
          </div>
        </div>
      </section>
      
      <!-- Accessibility -->
      <section class="ds-section" id="accessibility">
        <div class="ds-section-header">
          <div>
            <h2 class="ds-section-title">Accessibility</h2>
            <p class="ds-section-desc">WCAG 2.1 AA compliant guidelines.</p>
          </div>
          <span class="ds-section-badge">
            <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="10"/><path d="M12 16v-4"/></svg>
            AA Standard
          </span>
        </div>
        
        <div class="ds-component">
          <div class="ds-component-header">
            <span class="ds-component-title">Guidelines & Examples</span>
            <button class="btn-copy" onclick="copyCode('a11y-focus')">
              <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect x="9" y="9" width="13" height="13" rx="2"/><path d="M5 15H4a2 2 0 0 1-2-2V4a2 2 0 0 1 2-2h9a2 2 0 0 1 2 2v1"/></svg>
              Copy
            </button>
          </div>
          <div class="ds-component-preview">
            <div style="display: grid; grid-template-columns: repeat(auto-fit, minmax(280px, 1fr)); gap: 16px;">
              <!-- Color Contrast -->
              <div style="display: grid; grid-template-columns: 1fr 1fr; gap: 8px;">
                <div style="padding: 16px; background: white; border: 1px solid var(--slate-200); border-radius: 8px; text-align: center;">
                  <div style="font-size: 0.875rem; font-weight: 600; color: var(--slate-900);">Aa</div>
                  <div style="font-size: 0.6875rem; color: var(--slate-500); margin-top: 4px;">4.5:1 ✓</div>
                </div>
                <div style="padding: 16px; background: var(--slate-900); border-radius: 8px; text-align: center;">
                  <div style="font-size: 0.875rem; font-weight: 600; color: white;">Aa</div>
                  <div style="font-size: 0.6875rem; color: var(--slate-400); margin-top: 4px;">4.5:1 ✓</div>
                </div>
                <div style="padding: 16px; background: var(--primary-600); border-radius: 8px; text-align: center;">
                  <div style="font-size: 0.875rem; font-weight: 600; color: white;">Aa</div>
                  <div style="font-size: 0.6875rem; color: var(--primary-200); margin-top: 4px;">4.5:1 ✓</div>
                </div>
                <div style="padding: 16px; background: var(--error-600); border-radius: 8px; text-align: center;">
                  <div style="font-size: 0.875rem; font-weight: 600; color: white;">Aa</div>
                  <div style="font-size: 0.6875rem; color: var(--error-200); margin-top: 4px;">4.5:1 ✓</div>
                </div>
              </div>
              <!-- Focus States & Guidelines -->
              <div style="display: flex; flex-direction: column; gap: 12px;">
                <div style="display: flex; flex-wrap: wrap; gap: 10px; align-items: center; padding: 12px; background: var(--slate-50); border-radius: 8px; border: 1px solid var(--slate-200);">
                  <button class="btn btn-primary" style="outline: 2px solid var(--primary-600); outline-offset: 2px;">Focus</button>
                  <button class="btn btn-secondary" style="outline: 2px solid var(--slate-400); outline-offset: 2px;">Focus</button>
                  <input type="text" value="Focus" style="padding: 6px 10px; border: 2px solid var(--primary-500); border-radius: 6px; outline: none; width: 80px;">
                </div>
                <div style="background: var(--slate-50); padding: 12px; border-radius: 8px; border: 1px solid var(--slate-200);">
                  <ul style="font-size: 0.75rem; color: var(--slate-600); line-height: 1.7; margin-left: 16px;">
                    <li>Logical tab order (top→bottom, left→right)</li>
                    <li>Focusable: buttons, links, inputs, selects</li>
                    <li>Escape key closes modals/dropdowns</li>
                    <li>Arrow keys for radio groups</li>
                  </ul>
                </div>
              </div>
            </div>
          </div>
          <div class="ds-component-code">
            <div class="ds-component-code-header">
              <span class="ds-component-code-lang">CSS</span>
            </div>
            <pre id="a11y-focus"><code><span class="token-comment">/* Focus visible for keyboard navigation */</span>
<span class="token-tag">:focus-visible</span> {
  <span class="token-attr">outline</span>: <span class="token-value">2px solid var(--primary-600)</span>;
  <span class="token-attr">outline-offset</span>: <span class="token-value">2px</span>;
}
<span class="token-tag">.sr-only</span> {
  <span class="token-attr">position</span>: <span class="token-value">absolute</span>;
  <span class="token-attr">width</span>: <span class="token-value">1px; height: 1px</span>;
  <span class="token-attr">overflow</span>: <span class="token-value">hidden</span>;
}</code></pre>
          </div>
        </div>
      </section>
      
      <!-- Patterns -->
