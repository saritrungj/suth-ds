          <span class="avatar avatar-lg" style="background: var(--primary-600);">JD</span>
          <div>
            <div style="font-weight: 600;">John Doe</div>
            <div class="text-sm text-muted">ID: PT-001234</div>
            <div class="text-sm text-muted">DOB: March 15, 1985</div>
          </div>
        </div>
        <p style="color: var(--text-secondary);">This is a sample modal dialog demonstrating the modal component. You can place any content here including forms, tables, or detailed information.</p>
      </div>
      <div class="modal-footer">
        <button class="btn btn-secondary" onclick="closeModal('modalBasic')"><svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><line x1="18" y1="6" x2="6" y2="18"/><line x1="6" y1="6" x2="18" y2="18"/></svg> Close</button>
        <button class="btn btn-primary" onclick="showToast('Changes saved!', 'success'); closeModal('modalBasic')"><svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polyline points="20 6 9 17 4 12"/></svg> Save Changes</button>
      </div>
    </div>
  </div>
  
