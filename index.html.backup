        </div>
      </section>
      
      <!-- Grid -->
      <section class="ds-section" id="grid">
        <div class="ds-section-header">
          <div>
            <h2 class="ds-section-title">Grid System</h2>
            <p class="ds-section-desc">Flexible grid system for creating responsive layouts.</p>
          </div>
          <span class="ds-section-badge">
            <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect x="3" y="3" width="7" height="7"/><rect x="14" y="3" width="7" height="7"/><rect x="14" y="14" width="7" height="7"/><rect x="3" y="14" width="7" height="7"/></svg>
            12 Columns
          </span>
        </div>
        
        <div class="ds-component">
          <div class="ds-component-header">
            <span class="ds-component-title">Grid Columns</span>
            <button class="btn-copy" onclick="copyCode('grid-columns')">
              <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect x="9" y="9" width="13" height="13" rx="2"/><path d="M5 15H4a2 2 0 0 1-2-2V4a2 2 0 0 1 2-2h9a2 2 0 0 1 2 2v1"/></svg>
              Copy
            </button>
          </div>
          <div class="ds-component-preview">
            <div class="preview-stack">
              <div class="grid" style="display: grid; grid-template-columns: repeat(12, 1fr); gap: 8px;">
                <div class="col-12" style="grid-column: span 12; background: var(--primary-100); padding: 12px; border-radius: var(--radius-md); text-align: center; font-weight: 500;">col-12</div>
              </div>
              <div class="grid" style="display: grid; grid-template-columns: repeat(12, 1fr); gap: 8px;">
                <div class="col-6" style="grid-column: span 6; background: var(--primary-100); padding: 12px; border-radius: var(--radius-md); text-align: center; font-weight: 500;">col-6</div>
                <div class="col-6" style="grid-column: span 6; background: var(--primary-100); padding: 12px; border-radius: var(--radius-md); text-align: center; font-weight: 500;">col-6</div>
              </div>
              <div class="grid" style="display: grid; grid-template-columns: repeat(12, 1fr); gap: 8px;">
                <div class="col-4" style="grid-column: span 4; background: var(--primary-100); padding: 12px; border-radius: var(--radius-md); text-align: center; font-weight: 500;">col-4</div>
                <div class="col-4" style="grid-column: span 4; background: var(--primary-100); padding: 12px; border-radius: var(--radius-md); text-align: center; font-weight: 500;">col-4</div>
                <div class="col-4" style="grid-column: span 4; background: var(--primary-100); padding: 12px; border-radius: var(--radius-md); text-align: center; font-weight: 500;">col-4</div>
              </div>
              <div class="grid" style="display: grid; grid-template-columns: repeat(12, 1fr); gap: 8px;">
                <div class="col-3" style="grid-column: span 3; background: var(--primary-100); padding: 12px; border-radius: var(--radius-md); text-align: center; font-weight: 500;">col-3</div>
                <div class="col-3" style="grid-column: span 3; background: var(--primary-100); padding: 12px; border-radius: var(--radius-md); text-align: center; font-weight: 500;">col-3</div>
                <div class="col-3" style="grid-column: span 3; background: var(--primary-100); padding: 12px; border-radius: var(--radius-md); text-align: center; font-weight: 500;">col-3</div>
                <div class="col-3" style="grid-column: span 3; background: var(--primary-100); padding: 12px; border-radius: var(--radius-md); text-align: center; font-weight: 500;">col-3</div>
              </div>
            </div>
          </div>
          <div class="ds-component-code">
            <div class="ds-component-code-header">
              <span class="ds-component-code-lang">HTML</span>
            </div>
            <pre id="grid-columns"><code><span class="token-comment">&lt;!-- Grid Container --&gt;</span>
<span class="token-tag">&lt;div</span> <span class="token-attr">class</span>=<span class="token-value">"grid"</span><span class="token-tag">&gt;</span>
  <span class="token-tag">&lt;div</span> <span class="token-attr">class</span>=<span class="token-value">"col-12"</span><span class="token-tag">&gt;</span>Full width<span class="token-tag">&lt;/div&gt;</span>
  
  <span class="token-tag">&lt;div</span> <span class="token-attr">class</span>=<span class="token-value">"col-6"</span><span class="token-tag">&gt;</span>Half width<span class="token-tag">&lt;/div&gt;</span>
  <span class="token-tag">&lt;div</span> <span class="token-attr">class</span>=<span class="token-value">"col-6"</span><span class="token-tag">&gt;</span>Half width<span class="token-tag">&lt;/div&gt;</span>
  
  <span class="token-tag">&lt;div</span> <span class="token-attr">class</span>=<span class="token-value">"col-4"</span><span class="token-tag">&gt;</span>One third<span class="token-tag">&lt;/div&gt;</span>
  <span class="token-tag">&lt;div</span> <span class="token-attr">class</span>=<span class="token-value">"col-4"</span><span class="token-tag">&gt;</span>One third<span class="token-tag">&lt;/div&gt;</span>
