                <input type="text" class="form-input is-success" value="somchai@email.com" readonly>
                <span class="form-hint" style="color: var(--success-600);"><svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polyline points="20 6 9 17 4 12"/></svg> Email is valid</span>
