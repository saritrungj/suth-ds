<span class="token-tag">&lt;div</span> <span class="token-attr">class</span>=<span class="token-value">"p-8"</span><span class="token-tag">&gt;</span>32px padding<span class="token-tag">&lt;/div&gt;</span>

<span class="token-comment">&lt;!-- Padding top, right, bottom, left --&gt;</span>
