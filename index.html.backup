<span class="token-tag">&lt;button</span> <span class="token-attr">class</span>=<span class="token-value">"btn btn-primary btn-elevate"</span><span class="token-tag">&gt;</span>Elevate<span class="token-tag">&lt;/button&gt;</span></code></pre>
          </div>
        </div>
        
        <!-- Button Groups -->
        <div class="ds-component">
          <div class="ds-component-header">
            <span class="ds-component-title">Button Groups</span>
            <button class="btn-copy" onclick="copyCode('btn-groups')">
              <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><rect x="9" y="9" width="13" height="13" rx="2"/></svg>
              Copy
            </button>
          </div>
          <div class="ds-component-preview">
            <div class="preview-row" style="align-items: center; flex-wrap: wrap; gap: 20px;">
              <div class="btn-group">
                <button class="btn btn-secondary btn-sm" onclick="setActiveBtn(this)">Day</button>
                <button class="btn btn-secondary btn-sm active" onclick="setActiveBtn(this)">Week</button>
                <button class="btn btn-secondary btn-sm" onclick="setActiveBtn(this)">Month</button>
              </div>
              <div class="btn-group">
                <button class="btn btn-secondary btn-sm" onclick="setActiveBtn(this)">
                  <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><line x1="8" y1="6" x2="21" y2="6"/><line x1="8" y1="12" x2="21" y2="12"/><line x1="8" y1="18" x2="21" y2="18"/></svg>
                </button>
                <button class="btn btn-secondary btn-sm active" onclick="setActiveBtn(this)">
                  <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><rect x="3" y="3" width="7" height="7"/><rect x="14" y="3" width="7" height="7"/></svg>
                </button>
              </div>
              <div class="btn-group-separated">
                <button class="btn btn-primary" onclick="showToast('Saved!', 'success')">
                  <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M19 21H5a2 2 0 0 1-2-2V5a2 2 0 0 1 2-2h11l5 5v11a2 2 0 0 1-2 2z"/></svg>
                  Save
                </button>
                <button class="btn btn-secondary" onclick="showToast('Cancelled', 'info')">Cancel</button>
              </div>
            </div>
          </div>
          <div class="ds-component-code">
            <div class="ds-component-code-header">
              <span class="ds-component-code-lang">HTML</span>
            </div>
            <pre id="btn-groups"><code><span class="token-comment">&lt;!-- Joined Group --&gt;</span>
<span class="token-tag">&lt;div</span> <span class="token-attr">class</span>=<span class="token-value">"btn-group"</span><span class="token-tag">&gt;</span>
  <span class="token-tag">&lt;button</span> <span class="token-attr">class</span>=<span class="token-value">"btn btn-secondary btn-sm"</span><span class="token-tag">&gt;</span>Day<span class="token-tag">&lt;/button&gt;</span>
  <span class="token-tag">&lt;button</span> <span class="token-attr">class</span>=<span class="token-value">"btn btn-secondary btn-sm active"</span><span class="token-tag">&gt;</span>Week<span class="token-tag">&lt;/button&gt;</span>
  <span class="token-tag">&lt;button</span> <span class="token-attr">class</span>=<span class="token-value">"btn btn-secondary btn-sm"</span><span class="token-tag">&gt;</span>Month<span class="token-tag">&lt;/button&gt;</span>
