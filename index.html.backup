  <span class="token-tag">&lt;i</span> <span class="token-attr">class</span>=<span class="token-value">"fa-solid fa-circle-minus"</span> <span class="token-attr">style</span>=<span class="token-value">"color: var(--error-500);"</span><span class="token-tag">&gt;&lt;/i&gt;</span>
  <span class="token-tag">&lt;span&gt;</span>Busy<span class="token-tag">&lt;/span&gt;</span>
<span class="token-tag">&lt;/div&gt;</span>

