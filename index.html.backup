          <div class="ds-component-code">
            <div class="ds-component-code-header">
              <span class="ds-component-code-lang">HTML</span>
            </div>
            <pre id="status-indicators"><code><span class="token-comment">&lt;!-- Status with SVG Icons --&gt;</span>
<span class="token-tag">&lt;div</span> <span class="token-attr">class</span>=<span class="token-value">"flex items-center gap-2"</span><span class="token-tag">&gt;</span>
  <span class="token-tag">&lt;i</span> <span class="token-attr">class</span>=<span class="token-value">"fa-solid fa-circle-check"</span> <span class="token-attr">style</span>=<span class="token-value">"color: var(--success-600);"</span><span class="token-tag">&gt;&lt;/i&gt;</span>
  <span class="token-tag">&lt;span&gt;</span>Online<span class="token-tag">&lt;/span&gt;</span>
<span class="token-tag">&lt;/div&gt;</span>

<span class="token-tag">&lt;div</span> <span class="token-attr">class</span>=<span class="token-value">"flex items-center gap-2"</span><span class="token-tag">&gt;</span>
  <span class="token-tag">&lt;i</span> <span class="token-attr">class</span>=<span class="token-value">"fa-solid fa-clock"</span> <span class="token-attr">style</span>=<span class="token-value">"color: var(--warning-500);"</span><span class="token-tag">&gt;&lt;/i&gt;</span>
  <span class="token-tag">&lt;span&gt;</span>Away<span class="token-tag">&lt;/span&gt;</span>
<span class="token-tag">&lt;/div&gt;</span>

