          </div>
          <div class="ds-component-preview">
            <div class="preview-row" style="align-items: center; flex-wrap: wrap; gap: 12px;">
              <button class="btn btn-primary">Normal</button>
              <button class="btn btn-primary" disabled>Disabled</button>
              <button class="btn btn-primary is-loading">Loading</button>
              <button class="btn btn-secondary" onclick="this.classList.toggle('is-loading'); this.textContent = this.classList.contains('is-loading') ? 'Loading...' : 'Click to Load'">Click to Load</button>
              <button class="btn btn-icon btn-primary" title="Edit">
                <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M11 4H4a2 2 0 0 0-2 2v14a2 2 0 0 0 2 2h14a2 2 0 0 0 2-2v-7"/><path d="M18.5 2.5a2.121 2.121 0 0 1 3 3L12 15l-4 1 1-4 9.5-9.5z"/></svg>
              </button>
              <button class="btn btn-primary btn-press-effect">Press</button>
              <button class="btn btn-primary btn-elevate">Elevate</button>
            </div>
            <div class="preview-row" style="margin-top: 16px; padding: 12px 16px; background: var(--slate-50); border-radius: 8px;">
              <span class="text-sm" style="color: var(--slate-600);">💡 Try: Click "Click to Load" button, hover over "Elevate" for shadow effect</span>
            </div>
          </div>
          <div class="ds-component-code">
            <div class="ds-component-code-header">
              <span class="ds-component-code-lang">HTML</span>
            </div>
            <pre id="btn-states"><code><span class="token-comment">&lt;!-- States --&gt;</span>
<span class="token-tag">&lt;button</span> <span class="token-attr">class</span>=<span class="token-value">"btn btn-primary"</span><span class="token-tag">&gt;</span>Normal<span class="token-tag">&lt;/button&gt;</span>
<span class="token-tag">&lt;button</span> <span class="token-attr">class</span>=<span class="token-value">"btn btn-primary"</span> <span class="token-attr">disabled</span><span class="token-tag">&gt;</span>Disabled<span class="token-tag">&lt;/button&gt;</span>
<span class="token-tag">&lt;button</span> <span class="token-attr">class</span>=<span class="token-value">"btn btn-primary is-loading"</span><span class="token-tag">&gt;</span>Loading<span class="token-tag">&lt;/button&gt;</span>

<span class="token-comment">&lt;!-- Icon Only --&gt;</span>
<span class="token-tag">&lt;button</span> <span class="token-attr">class</span>=<span class="token-value">"btn btn-icon btn-primary"</span> <span class="token-attr">title</span>=<span class="token-value">"Edit"</span><span class="token-tag">&gt;</span>
  <span class="token-tag">&lt;svg</span> <span class="token-attr">width</span>=<span class="token-value">"16"</span> <span class="token-attr">height</span>=<span class="token-value">"16"</span> <span class="token-attr">stroke</span>=<span class="token-value">"currentColor"</span><span class="token-tag">&gt;</span>...<span class="token-tag">&lt;/svg&gt;</span>
