      <!-- Progress -->
      <section class="ds-section" id="progress">
        <div class="ds-section-header">
          <div>
            <h2 class="ds-section-title">Progress & Loading</h2>
            <p class="ds-section-desc">Visual feedback for ongoing operations and loading states.</p>
          </div>
        </div>
        
        <div class="ds-component">
          <div class="ds-component-header">
            <span class="ds-component-title">Progress Bars</span>
            <button class="btn-copy" onclick="copyCode('progress-bars')">
              <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect x="9" y="9" width="13" height="13" rx="2"/><path d="M5 15H4a2 2 0 0 1-2-2V4a2 2 0 0 1 2-2h9a2 2 0 0 1 2 2v1"/></svg>
              Copy
            </button>
          </div>
          <div class="ds-component-preview">
            <div class="preview-stack" style="max-width: 500px; width: 100%;">
              <div>
                <div style="display: flex; justify-content: space-between; margin-bottom: 6px;">
                  <span class="text-sm">Uploading...</span>
                  <span class="text-sm text-muted">25%</span>
                </div>
                <div class="progress">
                  <div class="progress-bar" style="width: 25%;"></div>
                </div>
              </div>
              <div>
                <div style="display: flex; justify-content: space-between; margin-bottom: 6px;">
                  <span class="text-sm">Processing</span>
                  <span class="text-sm text-muted">50%</span>
                </div>
                <div class="progress progress-animated">
                  <div class="progress-bar progress-bar-success" style="width: 50%;"></div>
                </div>
              </div>
              <div>
                <div style="display: flex; justify-content: space-between; margin-bottom: 6px;">
                  <span class="text-sm">Warning State</span>
                  <span class="text-sm text-muted">75%</span>
                </div>
                <div class="progress">
                  <div class="progress-bar progress-bar-warning" style="width: 75%;"></div>
                </div>
              </div>
              <div>
                <div style="display: flex; justify-content: space-between; margin-bottom: 6px;">
                  <span class="text-sm">Complete</span>
                  <span class="text-sm text-muted">100%</span>
                </div>
                <div class="progress">
                  <div class="progress-bar progress-bar-error" style="width: 100%;"></div>
                </div>
              </div>
              <div>
                <div style="display: flex; justify-content: space-between; margin-bottom: 6px;">
                  <span class="text-sm">Small</span>
