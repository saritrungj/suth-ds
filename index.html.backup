        <!-- Button Styles: Variants + Sizes + Shapes -->
        <div class="ds-component">
          <div class="ds-component-header">
            <span class="ds-component-title">Button Styles</span>
            <button class="btn-copy" onclick="copyCode('btn-styles')">
