              Copy
            </button>
          </div>
          <div class="ds-component-preview">
            <!-- Variants -->
            <div class="preview-row" style="flex-wrap: wrap;">
              <button class="btn btn-primary" onclick="showToast('Primary action', 'info')">
                <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z"/><polyline points="14 2 14 8 20 8"/></svg>
                Primary
              </button>
              <button class="btn btn-success" onclick="showToast('Success action', 'success')">
                <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><polyline points="20 6 9 17 4 12"/></svg>
                Success
              </button>
              <button class="btn btn-danger" onclick="showToast('Danger action', 'error')">
                <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><polyline points="3 6 5 6 21 6"/><path d="M19 6v14a2 2 0 0 1-2 2H7a2 2 0 0 1-2-2V6"/></svg>
                Danger
              </button>
              <button class="btn btn-soft-warning">Soft Warning</button>
              <button class="btn btn-outline-info">Outline Info</button>
              <button class="btn btn-ghost-secondary">Ghost</button>
            </div>
            <!-- Sizes -->
            <div class="preview-row" style="margin-top: 16px; align-items: center; flex-wrap: wrap;">
