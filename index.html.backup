                  <select class="form-select"><option>1</option><option>2</option></select>
                </div>
                <div class="form-group">
                  <label class="form-label">Month</label>
                  <select class="form-select"><option>Jan</option><option>Feb</option></select>
                </div>
                <div class="form-group">
                  <label class="form-label">Year</label>
                  <select class="form-select"><option>2024</option><option>2023</option></select>
                </div>
              </div>
            </div>
          </div>
          <div class="ds-component-code">
            <div class="ds-component-code-header">
