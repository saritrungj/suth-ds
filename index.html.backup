            <div class="ds-component-code-header">
              <span class="ds-component-code-lang">HTML</span>
            </div>
            <pre id="btn-styles"><code><span class="token-comment">&lt;!-- Solid Variants --&gt;</span>
<span class="token-tag">&lt;button</span> <span class="token-attr">class</span>=<span class="token-value">"btn btn-primary"</span><span class="token-tag">&gt;</span>
  <span class="token-tag">&lt;svg</span> <span class="token-attr">width</span>=<span class="token-value">"14"</span> <span class="token-attr">height</span>=<span class="token-value">"14"</span> <span class="token-attr">stroke</span>=<span class="token-value">"currentColor"</span><span class="token-tag">&gt;</span>...<span class="token-tag">&lt;/svg&gt;</span> Primary
<span class="token-tag">&lt;/button&gt;</span>
<span class="token-tag">&lt;button</span> <span class="token-attr">class</span>=<span class="token-value">"btn btn-success"</span><span class="token-tag">&gt;</span>Success<span class="token-tag">&lt;/button&gt;</span>
<span class="token-tag">&lt;button</span> <span class="token-attr">class</span>=<span class="token-value">"btn btn-danger"</span><span class="token-tag">&gt;</span>Danger<span class="token-tag">&lt;/button&gt;</span>

<span class="token-comment">&lt;!-- Alternative Styles --&gt;</span>
<span class="token-tag">&lt;button</span> <span class="token-attr">class</span>=<span class="token-value">"btn btn-soft-warning"</span><span class="token-tag">&gt;</span>Soft<span class="token-tag">&lt;/button&gt;</span>
<span class="token-tag">&lt;button</span> <span class="token-attr">class</span>=<span class="token-value">"btn btn-outline-info"</span><span class="token-tag">&gt;</span>Outline<span class="token-tag">&lt;/button&gt;</span>
<span class="token-tag">&lt;button</span> <span class="token-attr">class</span>=<span class="token-value">"btn btn-ghost-secondary"</span><span class="token-tag">&gt;</span>Ghost<span class="token-tag">&lt;/button&gt;</span>

<span class="token-comment">&lt;!-- Sizes: btn-xs, btn-sm, btn-lg, btn-xl --&gt;</span>
<span class="token-tag">&lt;button</span> <span class="token-attr">class</span>=<span class="token-value">"btn btn-primary btn-sm"</span><span class="token-tag">&gt;</span>Small<span class="token-tag">&lt;/button&gt;</span>
<span class="token-tag">&lt;button</span> <span class="token-attr">class</span>=<span class="token-value">"btn btn-primary btn-lg"</span><span class="token-tag">&gt;</span>Large<span class="token-tag">&lt;/button&gt;</span>

<span class="token-comment">&lt;!-- Shapes --&gt;</span>
<span class="token-tag">&lt;button</span> <span class="token-attr">class</span>=<span class="token-value">"btn btn-primary"</span> <span class="token-attr">style</span>=<span class="token-value">"border-radius: 9999px;"</span><span class="token-tag">&gt;</span>Pill<span class="token-tag">&lt;/button&gt;</span>
<span class="token-tag">&lt;button</span> <span class="token-attr">class</span>=<span class="token-value">"btn btn-primary btn-block"</span><span class="token-tag">&gt;</span>Block<span class="token-tag">&lt;/button&gt;</span></code></pre>
          </div>
