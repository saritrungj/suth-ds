              Copy
            </button>
          </div>
          <div class="ds-component-preview">
            <div class="preview-row" style="gap: 24px; flex-wrap: wrap;">
              <button class="btn btn-primary is-loading">Loading...</button>
              <button class="btn btn-success is-loading">Saving...</button>
              <button class="btn btn-danger is-loading">Deleting...</button>
              <div style="display: flex; align-items: center; gap: 8px; color: var(--text-muted);">
                <span class="spinner"></span>
                <span>Processing...</span>
              </div>
            </div>
          </div>
          <div class="ds-component-code">
            <div class="ds-component-code-header">
              <span class="ds-component-code-lang">HTML</span>
            </div>
            <pre id="crud-loading"><code><span class="token-comment">&lt;!-- Loading button states --&gt;</span>
<span class="token-tag">&lt;button</span> <span class="token-attr">class</span>=<span class="token-value">"btn btn-primary is-loading"</span><span class="token-tag">&gt;</span>Loading...<span class="token-tag">&lt;/button&gt;</span>
<span class="token-tag">&lt;button</span> <span class="token-attr">class</span>=<span class="token-value">"btn btn-success is-loading"</span><span class="token-tag">&gt;</span>Saving...<span class="token-tag">&lt;/button&gt;</span>

<span class="token-comment">&lt;!-- Inline spinner --&gt;</span>
