              </div>
              <div class="p-1" style="background: var(--primary-100); border: 2px dashed var(--primary-400); border-radius: var(--radius-sm);">
                <div style="background: white; padding: 4px;">p-1</div>
              </div>
              <div class="p-2" style="background: var(--primary-100); border: 2px dashed var(--primary-400); border-radius: var(--radius-sm);">
                <div style="background: white; padding: 4px;">p-2</div>
              </div>
              <div class="p-3" style="background: var(--primary-100); border: 2px dashed var(--primary-400); border-radius: var(--radius-sm);">
                <div style="background: white; padding: 4px;">p-3</div>
              </div>
              <div class="p-4" style="background: var(--primary-100); border: 2px dashed var(--primary-400); border-radius: var(--radius-sm);">
                <div style="background: white; padding: 4px;">p-4</div>
              </div>
            </div>
          </div>
          <div class="ds-component-code">
            <div class="ds-component-code-header">
              <span class="ds-component-code-lang">HTML</span>
            </div>
            <pre id="spacing-padding"><code><span class="token-comment">&lt;!-- Padding all sides --&gt;</span>
<span class="token-tag">&lt;div</span> <span class="token-attr">class</span>=<span class="token-value">"p-0"</span><span class="token-tag">&gt;</span>No padding<span class="token-tag">&lt;/div&gt;</span>
