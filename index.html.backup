      <!-- Timeline -->
      <section class="ds-section" id="timeline">
        <div class="ds-section-header">
          <div>
            <h2 class="ds-section-title">Timeline</h2>
            <p class="ds-section-desc">Chronological display of events and activities.</p>
          </div>
        </div>
        
        <div class="ds-component">
          <div class="ds-component-header">
            <span class="ds-component-title">Timeline</span>
            <button class="btn-copy" onclick="copyCode('timeline-code')">
              <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect x="9" y="9" width="13" height="13" rx="2"/><path d="M5 15H4a2 2 0 0 1-2-2V4a2 2 0 0 1 2-2h9a2 2 0 0 1 2 2v1"/></svg>
              Copy
            </button>
          </div>
          <div class="ds-component-preview">
            <div class="timeline" style="max-width: 500px;">
              <div class="timeline-item">
                <div class="timeline-dot"></div>
                <div class="timeline-content">
                  <div class="timeline-title">Patient Admitted</div>
                  <div class="timeline-time">Today, 08:30 AM</div>
                  <div class="timeline-text">Patient Somchai Jaidee admitted to ward 3B. Initial vitals recorded.</div>
                </div>
              </div>
              <div class="timeline-item">
                <div class="timeline-dot success"></div>
                <div class="timeline-content">
                  <div class="timeline-title">Initial Diagnosis</div>
                  <div class="timeline-time">Today, 09:15 AM</div>
                  <div class="timeline-text">Dr. Smith completed initial examination. Ordered blood tests and X-ray.</div>
                </div>
              </div>
              <div class="timeline-item">
                <div class="timeline-dot warning"></div>
                <div class="timeline-content">
                  <div class="timeline-title">Lab Results Pending</div>
                  <div class="timeline-time">Today, 10:00 AM</div>
                  <div class="timeline-text">Blood samples sent to laboratory for analysis. Results expected in 2 hours.</div>
                </div>
              </div>
              <div class="timeline-item">
                <div class="timeline-dot error"></div>
                <div class="timeline-content">
                  <div class="timeline-title">Critical Alert</div>
                  <div class="timeline-time">Today, 11:30 AM</div>
                  <div class="timeline-text">Elevated white blood cell count detected. Antibiotics administered.</div>
                </div>
              </div>
            </div>
          </div>
          <div class="ds-component-code">
            <div class="ds-component-code-header">
              <span class="ds-component-code-lang">HTML</span>
            </div>
            <pre id="timeline-code"><code><span class="token-tag">&lt;div</span> <span class="token-attr">class</span>=<span class="token-value">"timeline"</span><span class="token-tag">&gt;</span>
  <span class="token-tag">&lt;div</span> <span class="token-attr">class</span>=<span class="token-value">"timeline-item"</span><span class="token-tag">&gt;</span>
    <span class="token-tag">&lt;div</span> <span class="token-attr">class</span>=<span class="token-value">"timeline-dot"</span><span class="token-tag">&gt;&lt;/div&gt;</span>
    <span class="token-tag">&lt;div</span> <span class="token-attr">class</span>=<span class="token-value">"timeline-content"</span><span class="token-tag">&gt;</span>
      <span class="token-tag">&lt;div</span> <span class="token-attr">class</span>=<span class="token-value">"timeline-title"</span><span class="token-tag">&gt;</span>Event Title<span class="token-tag">&lt;/div&gt;</span>
      <span class="token-tag">&lt;div</span> <span class="token-attr">class</span>=<span class="token-value">"timeline-time"</span><span class="token-tag">&gt;</span>Timestamp<span class="token-tag">&lt;/div&gt;</span>
      <span class="token-tag">&lt;div</span> <span class="token-attr">class</span>=<span class="token-value">"timeline-text"</span><span class="token-tag">&gt;</span>Description<span class="token-tag">&lt;/div&gt;</span>
    <span class="token-tag">&lt;/div&gt;</span>
  <span class="token-tag">&lt;/div&gt;</span>
<span class="token-tag">&lt;/div&gt;</span></code></pre>
          </div>
        </div>
      </section>
      
      <!-- Spacing -->
