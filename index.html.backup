          <div class="ds-component-code">
            <div class="ds-component-code-header">
              <span class="ds-component-code-lang">HTML</span>
            </div>
            <pre id="install-cdn"><code><span class="token-tag">&lt;!DOCTYPE html&gt;</span>
<span class="token-tag">&lt;html</span> <span class="token-attr">lang</span>=<span class="token-value">"th"</span><span class="token-tag">&gt;</span>
<span class="token-tag">&lt;head&gt;</span>
  <span class="token-tag">&lt;meta</span> <span class="token-attr">charset</span>=<span class="token-value">"UTF-8"</span><span class="token-tag">&gt;</span>
  <span class="token-tag">&lt;meta</span> <span class="token-attr">name</span>=<span class="token-value">"viewport"</span> <span class="token-attr">content</span>=<span class="token-value">"width=device-width, initial-scale=1.0"</span><span class="token-tag">&gt;</span>
  <span class="token-tag">&lt;title&gt;</span>My App<span class="token-tag">&lt;/title&gt;</span>
  
  <span class="token-comment">&lt;!-- Google Fonts: Anuphan --&gt;</span>
  <span class="token-tag">&lt;link</span> <span class="token-attr">rel</span>=<span class="token-value">"stylesheet"</span> <span class="token-attr">href</span>=<span class="token-value">"https://fonts.googleapis.com/css2?family=Anuphan:wght@300;400;500;600;700&display=swap"</span><span class="token-tag">&gt;</span>
  
  <span class="token-comment">&lt;!-- SUTH Design System CSS --&gt;</span>
  <span class="token-tag">&lt;link</span> <span class="token-attr">rel</span>=<span class="token-value">"stylesheet"</span> <span class="token-attr">href</span>=<span class="token-value">"suth-ds.min.css"</span><span class="token-tag">&gt;</span>
<span class="token-tag">&lt;/head&gt;</span>
<span class="token-tag">&lt;body&gt;</span>
  <span class="token-tag">&lt;button</span> <span class="token-attr">class</span>=<span class="token-value">"btn btn-primary"</span><span class="token-tag">&gt;</span>Get Started<span class="token-tag">&lt;/button&gt;</span>
  
  <span class="token-comment">&lt;!-- SUTH Design System JS (optional) --&gt;</span>
  <span class="token-tag">&lt;script</span> <span class="token-attr">src</span>=<span class="token-value">"suth-ds.min.js"</span><span class="token-tag">&gt;&lt;/script&gt;</span>
<span class="token-tag">&lt;/body&gt;</span>
<span class="token-tag">&lt;/html&gt;</span></code></pre>
