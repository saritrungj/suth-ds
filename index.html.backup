          </div>
        </div>
      </section>
            <!-- Forms -->
      <section class="ds-section" id="forms">
        <div class="ds-section-header">
          <div>
            <h2 class="ds-section-title">Forms</h2>
            <p class="ds-section-desc">Complete form controls with validation states, floating labels & interactive features.</p>
          </div>
          <span class="ds-section-badge">
            <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect x="3" y="3" width="18" height="18" rx="2"/><path d="M7 7h10"/><path d="M7 12h10"/><path d="M7 17h10"/></svg>
            5 Components
          </span>
        </div>
        
        <!-- Text Inputs & Labels (รวม States + Floating Labels + Validation) -->
        <div class="ds-component">
          <div class="ds-component-header">
            <span class="ds-component-title">Text Inputs & Labels</span>
            <button class="btn-copy" onclick="copyCode('form-inputs')">
              <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><rect x="9" y="9" width="13" height="13" rx="2"/></svg>
              Copy
            </button>
          </div>
          <div class="ds-component-preview">
            <div class="preview-responsive">
              <!-- Column 1: Standard Labels -->
              <div class="preview-stack" style="flex: 1; min-width: 260px;">
                <div class="form-group">
                  <label class="form-label">Default Input</label>
                  <input type="text" class="form-input" placeholder="Enter your name...">
                </div>
                <div class="form-group">
                  <label class="form-label">With Hint</label>
                  <input type="email" class="form-input" placeholder="email@example.com">
                  <span class="form-hint">We'll never share your email.</span>
                </div>
                <div class="form-group">
                  <label class="form-label">Disabled</label>
                  <input type="text" class="form-input" value="Disabled input" disabled>
                </div>
              </div>
              <!-- Column 2: Validation States -->
              <div class="preview-stack" style="flex: 1; min-width: 260px;">
                <div class="form-group">
                  <label class="form-label">Success State</label>
                  <input type="text" class="form-input is-success" value="valid@email.com" readonly>
                  <svg class="validation-icon success" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="var(--success-500)" stroke-width="2"><polyline points="20 6 9 17 4 12"/></svg>
                </div>
                <div class="form-group">
                  <label class="form-label">Error State</label>
                  <input type="text" class="form-input is-error" value="invalid-email">
                  <svg class="validation-icon error" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="var(--error-500)" stroke-width="2"><circle cx="12" cy="12" r="10"/><line x1="15" y1="9" x2="9" y2="15"/><line x1="9" y1="9" x2="15" y2="15"/></svg>
                  <span class="form-error">Please enter a valid email.</span>
                </div>
              </div>
              <!-- Column 3: Floating Labels -->
              <div class="preview-stack" style="flex: 1; min-width: 260px;">
                <div class="form-group floating-label-group">
                  <input type="text" class="form-input" placeholder=" " id="floatName">
                  <label class="floating-label" for="floatName">Full Name</label>
                </div>
                <div class="form-group floating-label-group">
                  <select class="form-select" id="floatDept">
                    <option value="" disabled selected></option>
                    <option value="cardiology">Cardiology</option>
                    <option value="neurology">Neurology</option>
                  </select>
                  <label class="floating-label" for="floatDept">Department</label>
                </div>
                <div class="form-group floating-label-group">
                  <textarea class="form-textarea" rows="2" placeholder=" " id="floatNotes"></textarea>
                  <label class="floating-label" for="floatNotes">Notes</label>
                </div>
              </div>
            </div>
          </div>
          <div class="ds-component-code">
            <div class="ds-component-code-header">
              <span class="ds-component-code-lang">HTML</span>
            </div>
            <pre id="form-inputs"><code><span class="token-comment">&lt;!-- Standard Input with Label --&gt;</span>
<span class="token-tag">&lt;div</span> <span class="token-attr">class</span>=<span class="token-value">"form-group"</span><span class="token-tag">&gt;</span>
  <span class="token-tag">&lt;label</span> <span class="token-attr">class</span>=<span class="token-value">"form-label"</span><span class="token-tag">&gt;</span>Email<span class="token-tag">&lt;/label&gt;</span>
  <span class="token-tag">&lt;input</span> <span class="token-attr">type</span>=<span class="token-value">"email"</span> <span class="token-attr">class</span>=<span class="token-value">"form-input"</span> <span class="token-attr">placeholder</span>=<span class="token-value">"email@example.com"</span><span class="token-tag">&gt;</span>
  <span class="token-tag">&lt;span</span> <span class="token-attr">class</span>=<span class="token-value">"form-hint"</span><span class="token-tag">&gt;</span>Helper text<span class="token-tag">&lt;/span&gt;</span>
<span class="token-tag">&lt;/div&gt;</span>

<span class="token-comment">&lt;!-- Validation States --&gt;</span>
<span class="token-tag">&lt;input</span> <span class="token-attr">class</span>=<span class="token-value">"form-input is-success"</span><span class="token-tag">&gt;</span>
<span class="token-tag">&lt;input</span> <span class="token-attr">class</span>=<span class="token-value">"form-input is-error"</span><span class="token-tag">&gt;</span>

<span class="token-comment">&lt;!-- Floating Label --&gt;</span>
<span class="token-tag">&lt;div</span> <span class="token-attr">class</span>=<span class="token-value">"form-group floating-label-group"</span><span class="token-tag">&gt;</span>
  <span class="token-tag">&lt;input</span> <span class="token-attr">type</span>=<span class="token-value">"text"</span> <span class="token-attr">class</span>=<span class="token-value">"form-input"</span> <span class="token-attr">placeholder</span>=<span class="token-value">" "</span> <span class="token-attr">id</span>=<span class="token-value">"name"</span><span class="token-tag">&gt;</span>
  <span class="token-tag">&lt;label</span> <span class="token-attr">class</span>=<span class="token-value">"floating-label"</span> <span class="token-attr">for</span>=<span class="token-value">"name"</span><span class="token-tag">&gt;</span>Full Name<span class="token-tag">&lt;/label&gt;</span>
<span class="token-tag">&lt;/div&gt;</span></code></pre>
          </div>
        </div>
        
        <!-- Input Types & Features (รวม Password + Search + Select + Textarea) -->
        <div class="ds-component">
          <div class="ds-component-header">
            <span class="ds-component-title">Input Types & Features</span>
            <button class="btn-copy" onclick="copyCode('form-types')">
              <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><rect x="9" y="9" width="13" height="13" rx="2"/></svg>
              Copy
            </button>
          </div>
          <div class="ds-component-preview">
            <div class="preview-responsive">
              <!-- Column 1: Password & Search -->
              <div class="preview-stack" style="flex: 1; min-width: 260px;">
                <div class="form-group">
                  <label class="form-label">Password Strength</label>
                  <div class="input-icon-wrapper">
                    <input type="password" class="form-input has-icon-right" placeholder="Enter password" id="strengthPassword" oninput="checkPasswordStrength(this.value)">
                    <svg class="input-icon input-icon-right" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" style="cursor: pointer;" onclick="togglePassword('strengthPassword', this)"><path d="M1 12s4-8 11-8 11 8 11 8-4 8-11 8-11-8-11-8z"/><circle cx="12" cy="12" r="3"/></svg>
                  </div>
                  <div class="password-strength-wrapper">
                    <div class="password-strength-bar">
                      <div class="password-strength-segment" id="seg1"></div>
                      <div class="password-strength-segment" id="seg2"></div>
                      <div class="password-strength-segment" id="seg3"></div>
                    </div>
                    <div class="password-strength-text" id="strengthText">Enter password</div>
                  </div>
                </div>
                <div class="form-group">
                  <label class="form-label">Search with Clear</label>
                  <div class="input-icon-wrapper input-clear-wrapper">
                    <svg class="input-icon" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><circle cx="11" cy="11" r="8"/><path d="m21 21-4.35-4.35"/></svg>
                    <input type="text" class="form-input" placeholder="Search..." id="searchClearInput" oninput="toggleClearBtn(this)">
                    <button class="input-clear-btn" onclick="clearInput('searchClearInput')">
                      <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="white" stroke-width="3"><line x1="18" y1="6" x2="6" y2="18"/><line x1="6" y1="6" x2="18" y2="18"/></svg>
                    </button>
                  </div>
                </div>
              </div>
              <!-- Column 2: Select & Sizes -->
              <div class="preview-stack" style="flex: 1; min-width: 260px;">
                <div class="form-group">
                  <label class="form-label">Select Department</label>
                  <select class="form-select" onchange="showToast(`Selected: ${this.options[this.selectedIndex].text}`, 'info')">
                    <option value="">Choose...</option>
                    <option value="cardiology">Cardiology</option>
                    <option value="neurology">Neurology</option>
                    <option value="orthopedics">Orthopedics</option>
                  </select>
                </div>
                <div class="form-group">
                  <label class="form-label">Input Sizes</label>
                  <div class="preview-row" style="gap: 8px;">
                    <input type="text" class="form-input form-input-sm" placeholder="Small" style="width: 80px;">
                    <input type="text" class="form-input" placeholder="Medium" style="width: 90px;">
                    <input type="text" class="form-input form-input-lg" placeholder="Large" style="width: 100px;">
                  </div>
                </div>
              </div>
              <!-- Column 3: Textarea with Counter -->
              <div class="preview-stack" style="flex: 1; min-width: 260px;">
                <div class="form-group char-counter-wrapper">
                  <label class="form-label">Medical Notes</label>
                  <textarea class="form-textarea" rows="4" placeholder="Enter notes..." maxlength="200" oninput="updateCharCounter(this, 'charCount')"></textarea>
                  <div class="char-counter" id="charCount">0 / 200</div>
                </div>
              </div>
            </div>
          </div>
          <div class="ds-component-code">
            <div class="ds-component-code-header">
              <span class="ds-component-code-lang">HTML</span>
            </div>
            <pre id="form-types"><code><span class="token-comment">&lt;!-- Password with Toggle --&gt;</span>
<span class="token-tag">&lt;div</span> <span class="token-attr">class</span>=<span class="token-value">"input-icon-wrapper"</span><span class="token-tag">&gt;</span>
  <span class="token-tag">&lt;input</span> <span class="token-attr">type</span>=<span class="token-value">"password"</span> <span class="token-attr">class</span>=<span class="token-value">"form-input has-icon-right"</span> <span class="token-attr">id</span>=<span class="token-value">"pwd"</span><span class="token-tag">&gt;</span>
  <span class="token-tag">&lt;svg</span> <span class="token-attr">class</span>=<span class="token-value">"input-icon input-icon-right"</span> <span class="token-attr">onclick</span>=<span class="token-value">"togglePassword('pwd', this)"</span><span class="token-tag">&gt;</span>...<span class="token-tag">&lt;/svg&gt;</span>
<span class="token-tag">&lt;/div&gt;</span>

<span class="token-comment">&lt;!-- Search with Clear --&gt;</span>
<span class="token-tag">&lt;div</span> <span class="token-attr">class</span>=<span class="token-value">"input-icon-wrapper input-clear-wrapper"</span><span class="token-tag">&gt;</span>
  <span class="token-tag">&lt;input</span> <span class="token-attr">type</span>=<span class="token-value">"text"</span> <span class="token-attr">class</span>=<span class="token-value">"form-input"</span> <span class="token-attr">placeholder</span>=<span class="token-value">"Search..."</span><span class="token-tag">&gt;</span>
  <span class="token-tag">&lt;button</span> <span class="token-attr">class</span>=<span class="token-value">"input-clear-btn"</span> <span class="token-attr">onclick</span>=<span class="token-value">"clearInput('id')"</span><span class="token-tag">&gt;</span>...<span class="token-tag">&lt;/button&gt;</span>
<span class="token-tag">&lt;/div&gt;</span>

<span class="token-comment">&lt;!-- Select --&gt;</span>
<span class="token-tag">&lt;select</span> <span class="token-attr">class</span>=<span class="token-value">"form-select"</span><span class="token-tag">&gt;</span>
  <span class="token-tag">&lt;option</span> <span class="token-attr">value</span>=<span class="token-value">""</span><span class="token-tag">&gt;</span>Choose...<span class="token-tag">&lt;/option&gt;</span>
<span class="token-tag">&lt;/select&gt;</span>

<span class="token-comment">&lt;!-- Textarea with Counter --&gt;</span>
<span class="token-tag">&lt;div</span> <span class="token-attr">class</span>=<span class="token-value">"form-group char-counter-wrapper"</span><span class="token-tag">&gt;</span>
  <span class="token-tag">&lt;textarea</span> <span class="token-attr">class</span>=<span class="token-value">"form-textarea"</span> <span class="token-attr">rows</span>=<span class="token-value">"4"</span> <span class="token-attr">maxlength</span>=<span class="token-value">"200"</span><span class="token-tag">&gt;&lt;/textarea&gt;</span>
  <span class="token-tag">&lt;div</span> <span class="token-attr">class</span>=<span class="token-value">"char-counter"</span><span class="token-tag">&gt;</span>0 / 200<span class="token-tag">&lt;/div&gt;</span>
<span class="token-tag">&lt;/div&gt;</span></code></pre>
          </div>
        </div>
        
        <!-- Input Groups -->
        <div class="ds-component">
          <div class="ds-component-header">
            <span class="ds-component-title">Input Groups</span>
            <button class="btn-copy" onclick="copyCode('form-groups')">
              <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><rect x="9" y="9" width="13" height="13" rx="2"/></svg>
              Copy
            </button>
          </div>
          <div class="ds-component-preview">
            <div class="preview-responsive">
              <div class="preview-stack" style="flex: 1; min-width: 260px;">
                <div class="form-group">
                  <label class="form-label">Text Addon</label>
                  <div class="input-group">
                    <span class="input-group-text">@</span>
                    <input type="text" class="form-input" placeholder="username">
                  </div>
                </div>
                <div class="form-group">
                  <label class="form-label">Multiple Addons</label>
                  <div class="input-group">
                    <span class="input-group-text">https://</span>
                    <input type="text" class="form-input" placeholder="example">
                    <span class="input-group-text">.com</span>
                  </div>
                </div>
              </div>
              <div class="preview-stack" style="flex: 1; min-width: 260px;">
                <div class="form-group">
                  <label class="form-label">With Button</label>
                  <div class="input-group">
                    <input type="text" class="form-input" placeholder="Search..." id="groupSearchInput">
                    <button class="btn btn-primary" onclick="const v=document.getElementById('groupSearchInput').value; showToast(v?'Searching...':'Enter term', v?'info':'warning')">
                      <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><circle cx="11" cy="11" r="8"/><path d="m21 21-4.35-4.35"/></svg>
                    </button>
                  </div>
                </div>
                <div class="form-group">
                  <label class="form-label">With Dropdown</label>
                  <div class="input-group">
                    <input type="text" class="form-input" placeholder="Select..." readonly>
                    <button class="btn btn-secondary" onclick="showToast('Menu opened', 'info')">
                      Action <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" style="margin-left: 4px;"><polyline points="6 9 12 15 18 9"/></svg>
                    </button>
                  </div>
                </div>
              </div>
            </div>
          </div>
          <div class="ds-component-code">
            <div class="ds-component-code-header">
              <span class="ds-component-code-lang">HTML</span>
            </div>
            <pre id="form-groups"><code><span class="token-comment">&lt;!-- Text Addon --&gt;</span>
<span class="token-tag">&lt;div</span> <span class="token-attr">class</span>=<span class="token-value">"input-group"</span><span class="token-tag">&gt;</span>
  <span class="token-tag">&lt;span</span> <span class="token-attr">class</span>=<span class="token-value">"input-group-text"</span><span class="token-tag">&gt;</span>@<span class="token-tag">&lt;/span&gt;</span>
  <span class="token-tag">&lt;input</span> <span class="token-attr">type</span>=<span class="token-value">"text"</span> <span class="token-attr">class</span>=<span class="token-value">"form-input"</span><span class="token-tag">&gt;</span>
<span class="token-tag">&lt;/div&gt;</span>

<span class="token-comment">&lt;!-- With Button --&gt;</span>
<span class="token-tag">&lt;div</span> <span class="token-attr">class</span>=<span class="token-value">"input-group"</span><span class="token-tag">&gt;</span>
  <span class="token-tag">&lt;input</span> <span class="token-attr">type</span>=<span class="token-value">"text"</span> <span class="token-attr">class</span>=<span class="token-value">"form-input"</span> <span class="token-attr">placeholder</span>=<span class="token-value">"Search..."</span><span class="token-tag">&gt;</span>
  <span class="token-tag">&lt;button</span> <span class="token-attr">class</span>=<span class="token-value">"btn btn-primary"</span><span class="token-tag">&gt;</span>
    <span class="token-tag">&lt;svg</span> <span class="token-attr">width</span>=<span class="token-value">"16"</span> <span class="token-attr">height</span>=<span class="token-value">"16"</span> <span class="token-attr">stroke</span>=<span class="token-value">"currentColor"</span><span class="token-tag">&gt;</span>...<span class="token-tag">&lt;/svg&gt;</span>
  <span class="token-tag">&lt;/button&gt;</span>
<span class="token-tag">&lt;/div&gt;</span></code></pre>
          </div>
        </div>
        
        <!-- Checkbox, Radio & Switch -->
        <div class="ds-component">
          <div class="ds-component-header">
            <span class="ds-component-title">Checkbox, Radio & Switch</span>
            <button class="btn-copy" onclick="copyCode('form-check')">
              <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><rect x="9" y="9" width="13" height="13" rx="2"/></svg>
              Copy
            </button>
          </div>
          <div class="ds-component-preview">
            <div class="preview-responsive">
              <div class="preview-stack" style="flex: 1;">
                <p class="text-sm" style="color: var(--text-muted); margin: 0 0 8px; font-weight: 500;">Checkbox</p>
                <label class="form-check">
                  <input type="checkbox" class="form-check-input" checked onchange="showToast(this.checked?'Email ON':'Email OFF', this.checked?'success':'info')">
                  <span class="form-check-label-text">Email notifications</span>
                </label>
                <label class="form-check">
                  <input type="checkbox" class="form-check-input" onchange="showToast(this.checked?'SMS ON':'SMS OFF', this.checked?'success':'info')">
                  <span class="form-check-label-text">SMS alerts</span>
                </label>
                <label class="form-check">
                  <input type="checkbox" class="form-check-input" disabled>
                  <span class="form-check-label-text">Disabled</span>
                </label>
              </div>
              <div class="preview-stack" style="flex: 1;">
                <p class="text-sm" style="color: var(--text-muted); margin: 0 0 8px; font-weight: 500;">Radio</p>
                <label class="form-check">
                  <input type="radio" name="gender" class="form-check-input" checked onchange="showToast('Male selected', 'info')">
                  <span class="form-check-label-text">Male</span>
                </label>
                <label class="form-check">
                  <input type="radio" name="gender" class="form-check-input" onchange="showToast('Female selected', 'info')">
                  <span class="form-check-label-text">Female</span>
                </label>
                <label class="form-check">
                  <input type="radio" name="gender" class="form-check-input" disabled>
                  <span class="form-check-label-text">Other</span>
                </label>
              </div>
              <div class="preview-stack" style="flex: 1;">
                <p class="text-sm" style="color: var(--text-muted); margin: 0 0 8px; font-weight: 500;">Switch</p>
                <label class="switch">
                  <input type="checkbox" class="switch-input" checked onchange="showToast(this.checked?'Active':'Inactive', this.checked?'success':'warning')">
                  <span class="switch-label">System Active</span>
                </label>
                <label class="switch">
                  <input type="checkbox" class="switch-input" onchange="showToast(this.checked?'Dark ON':'Dark OFF', 'info')">
                  <span class="switch-label">Dark Mode</span>
                </label>
                <label class="switch">
                  <input type="checkbox" class="switch-input" disabled>
                  <span class="switch-label">Maintenance</span>
                </label>
              </div>
            </div>
          </div>
          <div class="ds-component-code">
            <div class="ds-component-code-header">
              <span class="ds-component-code-lang">HTML</span>
            </div>
            <pre id="form-check"><code><span class="token-comment">&lt;!-- Checkbox --&gt;</span>
<span class="token-tag">&lt;label</span> <span class="token-attr">class</span>=<span class="token-value">"form-check"</span><span class="token-tag">&gt;</span>
  <span class="token-tag">&lt;input</span> <span class="token-attr">type</span>=<span class="token-value">"checkbox"</span> <span class="token-attr">class</span>=<span class="token-value">"form-check-input"</span> <span class="token-attr">checked</span><span class="token-tag">&gt;</span>
  <span class="token-tag">&lt;span</span> <span class="token-attr">class</span>=<span class="token-value">"form-check-label-text"</span><span class="token-tag">&gt;</span>Email<span class="token-tag">&lt;/span&gt;</span>
<span class="token-tag">&lt;/label&gt;</span>

<span class="token-comment">&lt;!-- Radio --&gt;</span>
<span class="token-tag">&lt;label</span> <span class="token-attr">class</span>=<span class="token-value">"form-check"</span><span class="token-tag">&gt;</span>
  <span class="token-tag">&lt;input</span> <span class="token-attr">type</span>=<span class="token-value">"radio"</span> <span class="token-attr">name</span>=<span class="token-value">"gender"</span> <span class="token-attr">class</span>=<span class="token-value">"form-check-input"</span><span class="token-tag">&gt;</span>
  <span class="token-tag">&lt;span</span> <span class="token-attr">class</span>=<span class="token-value">"form-check-label-text"</span><span class="token-tag">&gt;</span>Male<span class="token-tag">&lt;/span&gt;</span>
<span class="token-tag">&lt;/label&gt;</span>

<span class="token-comment">&lt;!-- Switch --&gt;</span>
<span class="token-tag">&lt;label</span> <span class="token-attr">class</span>=<span class="token-value">"switch"</span><span class="token-tag">&gt;</span>
  <span class="token-tag">&lt;input</span> <span class="token-attr">type</span>=<span class="token-value">"checkbox"</span> <span class="token-attr">class</span>=<span class="token-value">"switch-input"</span> <span class="token-attr">checked</span><span class="token-tag">&gt;</span>
  <span class="token-tag">&lt;span</span> <span class="token-attr">class</span>=<span class="token-value">"switch-label"</span><span class="token-tag">&gt;</span>Active<span class="token-tag">&lt;/span&gt;</span>
<span class="token-tag">&lt;/label&gt;</span></code></pre>
          </div>
        </div>
        
